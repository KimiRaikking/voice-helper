# ===== 语音输入配置 =====
# 复制本文件为 voice.env 后按需修改;voiced 启动时自动读取。
# (真实环境变量优先级更高,会覆盖这里)

# 识别引擎: whisper | sensevoice | paraformer
#   whisper    -> 多语言;中英混说友好
#   sensevoice -> 中文优化,带标点,极快
#   paraformer -> 中文 + 热词偏置(说错的词喂进 hotwords.txt,下次不再错)
VOICE_ENGINE=sensevoice

# 说话热键: alt_r(右Option/右Alt) / alt_l / ctrl_r / cmd_r / f5 ...
VOICE_KEY=alt_r

# 强制语言: zh / en ;留空=自动识别
VOICE_LANG=zh

# Whisper 模型:
#   mac     -> MLX 仓库, 如 mlx-community/whisper-large-v3-turbo
#   Windows -> faster-whisper 规格, 如 small / medium / large-v3
# WHISPER_MODEL=small

# SenseVoice 模型
# SENSEVOICE_MODEL=iic/SenseVoiceSmall

# Whisper 热词/上下文提示(只对 whisper 引擎生效)
# VOICE_PROMPT=以下是普通话技术对话。

# Paraformer 热词:这里写静态词;动态词放 hotwords.txt(每次转写实时读取)
# 用法: python add_hotword.py 时延 推理   (或 addhot 时延 推理)
# VOICE_HOTWORD=时延 推理 部署

# 其它开关(取消注释即启用)
# VOICE_SOUND=1      # 状态声音提示
# VOICE_NOTIFY=1     # 完成弹通知
# VOICE_NO_PASTE=1   # 只复制不自动粘贴
